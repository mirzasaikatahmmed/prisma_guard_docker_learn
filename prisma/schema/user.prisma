model User {
  id String @id @default(cuid())
  name String
  username String? @unique
  email String @unique
  password String
  role Role @default(USER)
  loginType LoginType @default(EMAIL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
}

enum Role {
  USER
  ADMIN
}

enum LoginType {
  EMAIL
  GOOGLE
  TWITTER
}